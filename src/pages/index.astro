---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Home"
  description="Nicholas Daly — Composer, Scholar, Nonprofit Strategist"
  section="home"
>
  <!-- HERO SECTION -->
  <section style="min-height: 80vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 8rem 2rem 3.5rem; text-align: center; border-bottom: 1px solid var(--border); position: relative;">
    <div class="container">
      <div style="margin-bottom: 1rem; font-family: 'Inter', sans-serif; font-size: 0.65rem; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gold);">
        Composer · Researcher · Strategist
      </div>

      <h1 style="font-size: clamp(2.2rem, 5vw, 3.5rem); font-weight: 400; color: var(--ink); margin-bottom: 0.8rem;">
        Nicholas<br><em style="color: var(--red); font-style: italic;">Daly</em>
      </h1>

      <div style="font-size: 1.15rem; font-style: italic; color: var(--ink-faded); max-width: 560px; margin: 0 auto; line-height: 1.65;">
        Re-enchanting algorithmic composition, securing $21M+ in capital grants, and building tools for the musical imagination.
      </div>
    </div>

    <div class="scroll-hint" style="position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);">
      ↓ Scroll
    </div>
  </section>

  <!-- AT A GLANCE SECTION -->
  <section class="section" style="border-bottom: 1px solid var(--border);">
    <div class="container">
      <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; font-weight: 300; letter-spacing: 0.2em; color: var(--gold); display: block; margin-bottom: 0.4rem;">AT A GLANCE</div>
      <h2 style="font-size: 2rem; font-weight: 500; margin-bottom: 1.5rem; color: var(--ink);">What I Do</h2>

      <!-- Stat Cards Grid -->
      <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin: 2rem 0;">
        <div style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative;" class="card">
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 300; color: var(--gold); margin-bottom: 0.5rem;">5</div>
          <div style="font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faded);">Thesis Chapters</div>
        </div>

        <div style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative;" class="card">
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 300; color: var(--gold); margin-bottom: 0.5rem;">$21M+</div>
          <div style="font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faded);">Grants Secured</div>
        </div>

        <div style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative;" class="card">
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 300; color: var(--gold); margin-bottom: 0.5rem;">10</div>
          <div style="font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faded);">Bestiary Creatures</div>
        </div>

        <div style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative;" class="card">
          <div style="font-family: 'JetBrains Mono', monospace; font-size: 1.8rem; font-weight: 300; color: var(--gold); margin-bottom: 0.5rem;">35</div>
          <div style="font-family: 'Inter', sans-serif; font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-faded);">Years in Music</div>
        </div>
      </div>

      <!-- Progress Bars -->
      <h3 style="font-size: 1.35rem; font-weight: 600; margin-top: 2rem; margin-bottom: 0.8rem; color: var(--ink-light);">Current Projects</h3>

      <div style="display: grid; grid-template-columns: 120px 1fr auto; gap: 1rem; align-items: center; margin: 0.5rem 0;">
        <div style="font-weight: 600; color: var(--ink); font-size: 0.9rem;">PhD Research</div>
        <div class="progress-track" style="display: flex; gap: 2px; margin: 0; height: 6px; border-radius: 3px; overflow: hidden; background: var(--parchment-dark);">
          <div class="progress-fill" style="background: var(--blue); border-radius: 3px; width: 60%; transition: width 0.5s ease;"></div>
        </div>
        <div class="status status-active" style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 3px; font-weight: 500; background: rgba(61,90,58,0.12); color: var(--green); white-space: nowrap;">In Progress</div>
      </div>

      <div style="display: grid; grid-template-columns: 120px 1fr auto; gap: 1rem; align-items: center; margin: 0.5rem 0;">
        <div style="font-weight: 600; color: var(--ink); font-size: 0.9rem;">Compositions</div>
        <div class="progress-track" style="display: flex; gap: 2px; margin: 0; height: 6px; border-radius: 3px; overflow: hidden; background: var(--parchment-dark);">
          <div class="progress-fill" style="background: var(--blue); border-radius: 3px; width: 25%; transition: width 0.5s ease;"></div>
        </div>
        <div class="status status-active" style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 3px; font-weight: 500; background: rgba(61,90,58,0.12); color: var(--green); white-space: nowrap;">In Progress</div>
      </div>

      <div style="display: grid; grid-template-columns: 120px 1fr auto; gap: 1rem; align-items: center; margin: 0.5rem 0;">
        <div style="font-weight: 600; color: var(--ink); font-size: 0.9rem;">MuseScore Plugins</div>
        <div class="progress-track" style="display: flex; gap: 2px; margin: 0; height: 6px; border-radius: 3px; overflow: hidden; background: var(--parchment-dark);">
          <div class="progress-fill" style="background: var(--gold); border-radius: 3px; width: 10%; transition: width 0.5s ease;"></div>
        </div>
        <div class="status status-planned" style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 3px; font-weight: 500; background: var(--gold-glow); color: var(--gold); white-space: nowrap;">Planning</div>
      </div>

      <div style="display: grid; grid-template-columns: 120px 1fr auto; gap: 1rem; align-items: center; margin: 0.5rem 0;">
        <div style="font-weight: 600; color: var(--ink); font-size: 0.9rem;">Nonprofit Consulting</div>
        <div class="progress-track" style="display: flex; gap: 2px; margin: 0; height: 6px; border-radius: 3px; overflow: hidden; background: var(--parchment-dark);">
          <div class="progress-fill" style="background: var(--blue); border-radius: 3px; width: 80%; transition: width 0.5s ease;"></div>
        </div>
        <div class="status status-active" style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 3px; font-weight: 500; background: rgba(61,90,58,0.12); color: var(--green); white-space: nowrap;">Ongoing</div>
      </div>
    </div>
  </section>

  <!-- THESIS STATEMENT -->
  <section class="section">
    <div class="container">
      <div class="ornament-box" style="border: 1px solid var(--border); padding: 2rem 2.5rem; margin: 2rem 0; position: relative; text-align: center; font-style: italic; color: var(--ink-light); line-height: 1.72;">
        <p style="margin: 0;">A gorgeous multimedia book exploring the imaginal cartography of inspiration and cultural transmission of a fantastical world that proves the academic argument for an autodidacticanism based on a <strong>technics of inner revelation</strong>.</p>
      </div>
    </div>
  </section>

  <!-- NAVIGATE SECTION -->
  <section class="section section-alt">
    <div class="container">
      <div style="font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; font-weight: 300; letter-spacing: 0.2em; color: var(--gold); display: block; margin-bottom: 0.4rem;">EXPLORE</div>
      <h2 style="font-size: 2rem; font-weight: 500; margin-bottom: 1.5rem; color: var(--ink);">Navigate My Work</h2>

      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin: 2rem 0;">
        <!-- Thesis & Chapters -->
        <a href={`${base}research/`} style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative; text-decoration: none; color: inherit; display: block;" class="card">
          <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.6rem;">Thesis & Chapters</h4>
          <p style="font-size: 0.9rem; color: var(--ink-light); margin: 0; line-height: 1.6;">Explore the five movements of my doctoral research.</p>
          <div style="margin-top: 0.8rem;">
            <span class="tag" style="display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; background: var(--gold-glow); color: var(--gold); padding: 0.18rem 0.55rem; border-radius: 2px;">5 chapters</span>
          </div>
        </a>

        <!-- Theoretical Framework -->
        <a href={`${base}research/framework/`} style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative; text-decoration: none; color: inherit; display: block;" class="card">
          <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.6rem;">Theoretical Framework</h4>
          <p style="font-size: 0.9rem; color: var(--ink-light); margin: 0; line-height: 1.6;">The philosophical constellation guiding my research.</p>
          <div style="margin-top: 0.8rem;">
            <span class="tag" style="display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; background: var(--gold-glow); color: var(--gold); padding: 0.18rem 0.55rem; border-radius: 2px;">8 theorists</span>
          </div>
        </a>

        <!-- Bibliography -->
        <a href={`${base}research/bibliography/`} style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative; text-decoration: none; color: inherit; display: block;" class="card">
          <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.6rem;">Bibliography</h4>
          <p style="font-size: 0.9rem; color: var(--ink-light); margin: 0; line-height: 1.6;">Annotated sources across three research strands.</p>
          <div style="margin-top: 0.8rem;">
            <span class="tag" style="display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; background: var(--gold-glow); color: var(--gold); padding: 0.18rem 0.55rem; border-radius: 2px;">annotated</span>
          </div>
        </a>

        <!-- Compositions -->
        <a href={`${base}portfolio/`} style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative; text-decoration: none; color: inherit; display: block;" class="card">
          <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.6rem;">Compositions</h4>
          <p style="font-size: 0.9rem; color: var(--ink-light); margin: 0; line-height: 1.6;">My creative practice across ensemble and media types.</p>
          <div style="margin-top: 0.8rem;">
            <span class="tag-red" style="display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; background: rgba(139,26,26,0.08); color: var(--red); padding: 0.18rem 0.55rem; border-radius: 2px;">creative practice</span>
          </div>
        </a>

        <!-- The Bestiary -->
        <a href={`${base}bestiary/`} style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative; text-decoration: none; color: inherit; display: block;" class="card">
          <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.6rem;">The Bestiary</h4>
          <p style="font-size: 0.9rem; color: var(--ink-light); margin: 0; line-height: 1.6;">AI-enhanced creatures as compositional philosophies.</p>
          <div style="margin-top: 0.8rem;">
            <span class="tag-red" style="display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; background: rgba(139,26,26,0.08); color: var(--red); padding: 0.18rem 0.55rem; border-radius: 2px;">core artifact</span>
          </div>
        </a>

        <!-- MuseScore Plugins -->
        <a href={`${base}tools/`} style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative; text-decoration: none; color: inherit; display: block;" class="card">
          <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.6rem;">MuseScore Plugins</h4>
          <p style="font-size: 0.9rem; color: var(--ink-light); margin: 0; line-height: 1.6;">Technical tools for the musical imagination.</p>
          <div style="margin-top: 0.8rem;">
            <span class="tag-blue" style="display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; background: rgba(42,74,107,0.08); color: var(--blue); padding: 0.18rem 0.55rem; border-radius: 2px;">technical</span>
          </div>
        </a>

        <!-- Professional CV -->
        <a href={`${base}cv/`} style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative; text-decoration: none; color: inherit; display: block;" class="card">
          <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.6rem;">Professional CV</h4>
          <p style="font-size: 0.9rem; color: var(--ink-light); margin: 0; line-height: 1.6;">Education, fellowships, and professional experience.</p>
          <div style="margin-top: 0.8rem;">
            <span class="tag-green" style="display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; background: rgba(61,90,58,0.08); color: var(--green); padding: 0.18rem 0.55rem; border-radius: 2px;">career</span>
          </div>
        </a>

        <!-- Research Log -->
        <a href={`${base}updates/`} style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative; text-decoration: none; color: inherit; display: block;" class="card">
          <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.6rem;">Research Log</h4>
          <p style="font-size: 0.9rem; color: var(--ink-light); margin: 0; line-height: 1.6;">Latest updates and research milestones.</p>
          <div style="margin-top: 0.8rem;">
            <span class="tag" style="display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; background: var(--gold-glow); color: var(--gold); padding: 0.18rem 0.55rem; border-radius: 2px;">blog</span>
          </div>
        </a>

        <!-- About Me -->
        <a href={`${base}about/`} style="border: 1px solid var(--border); padding: 1.8rem; transition: all var(--transition); position: relative; text-decoration: none; color: inherit; display: block;" class="card">
          <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.6rem;">About Me</h4>
          <p style="font-size: 0.9rem; color: var(--ink-light); margin: 0; line-height: 1.6;">Background, musical practice, and institutional context.</p>
          <div style="margin-top: 0.8rem;">
            <span class="tag" style="display: inline-block; font-family: 'JetBrains Mono', monospace; font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase; background: var(--gold-glow); color: var(--gold); padding: 0.18rem 0.55rem; border-radius: 2px;">bio</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- LATEST UPDATES -->
  <section class="section">
    <div class="container">
      <h2 style="font-size: 2rem; font-weight: 500; margin-bottom: 1.5rem; color: var(--ink);">Latest Updates</h2>

      <div class="update-card" style="border-bottom: 1px solid var(--border-light); padding: 1.8rem 0;">
        <div class="update-date" style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--gold); margin-bottom: 0.3rem;">19 March 2026</div>
        <h3 style="margin-top: 0; font-size: 1.15rem; color: var(--red); font-weight: 600;">Website Rebuilt</h3>
        <p style="font-size: 0.92rem; color: var(--ink-light); margin-bottom: 0;">Complete redesign of my professional home base with new research pages, portfolio, and compositional bestiary documentation.</p>
      </div>

      <div class="update-card" style="border-bottom: 1px solid var(--border-light); padding: 1.8rem 0;">
        <div class="update-date" style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--gold); margin-bottom: 0.3rem;">March 2026</div>
        <h3 style="margin-top: 0; font-size: 1.15rem; color: var(--red); font-weight: 600;">USAL Pre-Inscription Window Open</h3>
        <p style="font-size: 0.92rem; color: var(--ink-light); margin-bottom: 0;">Beginning the formal doctoral process at Universidad de Salamanca with pre-inscription period now available.</p>
      </div>

      <div class="update-card" style="border-bottom: none; padding: 1.8rem 0;">
        <div class="update-date" style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--gold); margin-bottom: 0.3rem;">February 2026</div>
        <h3 style="margin-top: 0; font-size: 1.15rem; color: var(--red); font-weight: 600;">Funding Strategy Completed</h3>
        <p style="font-size: 0.92rem; color: var(--ink-light); margin-bottom: 0;">Finished comprehensive funding strategy for nonprofit consulting work, securing commitments for multiple grant-funded initiatives.</p>
      </div>

      <p style="margin-top: 1.5rem; color: var(--ink-light);">
        <a href={`${base}updates/`} style="color: var(--gold); text-decoration: none;">View all updates →</a>
      </p>
    </div>
  </section>
</BaseLayout>
